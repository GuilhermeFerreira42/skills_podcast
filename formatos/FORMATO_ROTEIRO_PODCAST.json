{
  "formato": "roteiro_podcast",
  "versao": "2.0",
  "descricao": "Formato padrao de saida do orquestrador. Entrada para o produtor de audio.",

  "metadados": {
    "tipo": "objeto",
    "campos": {
      "titulo_projeto": {"tipo": "string"},
      "genero": {"tipo": "string"},
      "data_geracao": {"tipo": "string"},
      "versao_formato": {"tipo": "string", "valor_fixo": "2.0"},
      "total_episodios": {"tipo": "int"},
      "total_falas": {"tipo": "int"},
      "total_disfluencias": {"tipo": "int", "descricao": "Quantas pausas/interjeicoes foram inseridas para naturalidade"}
    }
  },

  "speakers": {
    "tipo": "array",
    "min": 1,
    "max": 4,
    "item": {
      "id": {"tipo": "string"},
      "papel": {"tipo": "string"},
      "descricao": {"tipo": "string"},
      "voz_sugerida": {"tipo": "string", "opcional": true},
      "genero": {"tipo": "string", "opcional": true}
    }
  },

  "episodios": {
    "tipo": "array",
    "item": {
      "numero": {"tipo": "int"},
      "titulo": {"tipo": "string"},
      "segmentos": {
        "tipo": "array",
        "item": {
          "nome": {"tipo": "string"},
          "funcao": {"tipo": "string", "opcoes": ["abertura", "historia", "conceito", "mecanismo", "implicacao", "protocolo", "fecho"]},
          "tamanho": {"tipo": "string", "opcoes": ["curto", "medio", "longo"]},
          "falas": {
            "tipo": "array",
            "min_items": 3,
            "max_items": 8,
            "item": {
              "speaker_id": {"tipo": "string"},
              "texto": {"tipo": "string", "descricao": "Texto plano, sem markdown. Pode conter disfluencias como 'Ah, entendi', 'Pera ai'"},
              "disfluencia": {"tipo": "boolean", "opcional": true, "descricao": "Se true, esta fala e uma pausa/interjeicao para naturalidade"}
            }
          }
        }
      }
    }
  },

  "estado_da_obra": {
    "tipo": "objeto",
    "descricao": "Snapshot do estado de producao. Usado para retomada.",
    "campos": {
      "ultimo_episodio_concluido": {"tipo": "int"},
      "ultimo_segmento_concluido": {"tipo": "string"},
      "total_chamadas_gastas": {"tipo": "int"},
      "status_geral": {"tipo": "string", "opcoes": ["em_andamento", "concluido", "interrompido"]}
    }
  }
}
